# ─────────────────────────────────────────────────────────────────────────────
# Copiar para .env e preencher. NÃO commitar o .env real.
# Estes valores têm de existir em DOIS sítios:
#   - Trigger.dev  → todos exceto SHOPIFY_WEBHOOK_SECRET e TRIGGER_SECRET_KEY
#   - Vercel       → SHOPIFY_WEBHOOK_SECRET, TRIGGER_SECRET_KEY, TRIGGER_PROJECT_REF,
#                    e os do filtro Multibanco (MB_GATEWAY_NAME)
# ─────────────────────────────────────────────────────────────────────────────

# Shopify Admin API
SHOPIFY_STORE_DOMAIN=minha-loja.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10

# Segredo do webhook Shopify (Notifications → chave de assinatura, ou secret da app).
# Usado pela função Vercel para validar o HMAC.
SHOPIFY_WEBHOOK_SECRET=

# EvolutionAPI
EVOLUTION_BASE_URL=https://evolution.exemplo.com
EVOLUTION_INSTANCE=nome-da-instancia
EVOLUTION_API_KEY=

# Número do dono que recebe o aviso ao 5º dia (só dígitos, com indicativo).
OWNER_WHATSAPP_NUMBER=351939395122

# Trigger.dev — para a função Vercel disparar a tarefa.
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxxxxxxxxx
TRIGGER_PROJECT_REF=proj_xxxxxxxxxxxx

# ── Multibanco ────────────────────────────────────────────────────────────────
# A deteção do Multibanco e a leitura de Entidade/Referência/Valor são automáticas
# (via Shopify Payments / transactions da encomenda). Não é preciso configurar nada.

# Opcional: pôr "true" para testar o fluxo em minutos em vez de dias.
USE_TEST_OFFSETS=false
